# LLM — NVIDIA NIM (https://build.nvidia.com)
NVIDIA_API_KEY=your_nvidia_api_key_here

# News APIs
GNEWS_API_KEY=your_gnews_api_key_here          # https://gnews.io/dashboard
THENEWSAPI_KEY=your_thenewsapi_key_here        # https://www.thenewsapi.com/account/dashboard
CURRENTS_API_KEY=your_currents_api_key_here    # https://currentsapi.services/en/profile

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here         # from @BotFather
TELEGRAM_CHAT_ID=your_chat_id_here             # your personal chat ID
